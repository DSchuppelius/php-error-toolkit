{
    "name": "dschuppelius/php-error-toolkit",
    "description": "Logging and error handling foundation for the Schuppelius PHP toolkits (PSR-3 loggers, global error handler, LoggerRegistry, Laravel bridge)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Joerg Schuppelius",
            "email": "info@schuppelius.org"
        }
    ],
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    },
    "require": {
        "php": ">=8.1 <8.6",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ERRORToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.27",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/container": "^10.0|^11.0|^12.0"
    },
    "suggest": {
        "illuminate/support": "Aktiviert die Laravel-Bridge: auto-discovertes ServiceProvider bindet die LoggerRegistry an den Laravel-Log-Channel"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ERRORToolkit\\Laravel\\ErrorToolkitServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint --test",
        "format:fix": "vendor/bin/pint",
        "lint": "vendor/bin/phpstan analyse --memory-limit=1G",
        "qa": [
            "@format",
            "@lint",
            "@test"
        ]
    }
}
